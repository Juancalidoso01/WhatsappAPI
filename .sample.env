# ===== WhatsApp / Meta App Configuration =====
ACCESS_TOKEN=ADD_APP_TOKEN_HERE
APP_SECRET=ADD_APP_SECRET_HERE
APP_ID=ADD_APP_ID_HERE
PHONE_NUMBER_ID=ADD_PHONE_NUMBER_ID_HERE
WABA_ID=ADD_WABA_ID_HERE
VERIFY_TOKEN=ADD_VERIFY_TOKEN_HERE

# ===== Integration API (external systems / CRM) =====
INTEGRATION_API_KEY=

# ===== Dashboard security =====
# Cuando está definida, el panel exige login (cookie de sesión 7 días).
DASHBOARD_PASSWORD=
# Opcional: firma de sesión (por defecto usa APP_SECRET o DASHBOARD_PASSWORD)
# DASHBOARD_SECRET=

# Vercel Cron: envía Authorization Bearer CRON_SECRET cada minuto a /api/campaigns/cron/tick
CRON_SECRET=

# Solo en pruebas: permite POST /api/simulate-incoming en producción
# ALLOW_SIMULATE=true

# ===== Server Configuration =====
PORT=8080
# URL pública HTTPS (requerida para WhatsApp Flows con endpoint dinámico)
PUBLIC_BASE_URL=https://whatsapp-api-ten-tau.vercel.app
# Opcional: URL pública de imagen de tarjeta (si no, usa /assets/punto-pago-card.png)
# CARD_IMAGE_URL=

# ===== Redis (only used locally) =====
REDIS_HOST=localhost
REDIS_PORT=6379
